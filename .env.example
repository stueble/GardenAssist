# GardenAssist Docker configuration
# Copy this file to .env and adjust values as needed.

# Port the app is reachable on the host (default: 3110)
# Change to avoid conflicts with other services.
GARDENASSIST_PORT=3110

# Image version to pull from ghcr.io (default: latest)
# Set to a specific tag to pin a version, e.g. 1.2.0 or sha-abc1234.
GARDENASSIST_VERSION=latest
